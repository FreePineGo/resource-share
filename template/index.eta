<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>资源站 - 游戏与短剧资源分享</title>
  <meta name="description" content="分享游戏、短剧等网盘资源，包含手机游戏、电脑游戏、PS4游戏、SWITCH游戏、短剧资源等">
  <meta name="keywords" content="游戏资源,短剧资源,网盘分享,手机游戏,电脑游戏,PS4,SWITCH">
  <link rel="canonical" href="https://your-domain.com/">
  <link rel="stylesheet" href="css/style.css">

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "资源站",
    "description": "游戏与短剧资源分享平台",
    "url": "https://your-domain.com/",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://your-domain.com/category/{search_term_string}.html",
      "query-input": "required name=search_term_string"
    }
  }
  </script>
</head>
<body>
  <header class="header">
    <div class="header-content">
      <a href="index.html" class="logo">资源站</a>
      <button class="menu-toggle" onclick="toggleMenu()">☰</button>
      <nav class="nav" id="nav">
        <a href="category/mobile-games.html" class="nav-link <%= it.category === 'mobile-games' ? 'active' : '' %>">📱 手机游戏</a>
        <a href="category/pc-games.html" class="nav-link <%= it.category === 'pc-games' ? 'active' : '' %>">💻 电脑游戏</a>
        <a href="category/ps4-games.html" class="nav-link <%= it.category === 'ps4-games' ? 'active' : '' %>">🎮 PS4游戏</a>
        <a href="category/switch-games.html" class="nav-link <%= it.category === 'switch-games' ? 'active' : '' %>">🕹️ SWITCH游戏</a>
        <a href="category/short-drama.html" class="nav-link <%= it.category === 'short-drama' ? 'active' : '' %>">📺 短剧资源</a>
      </nav>
      <div class="search-box">
        <input type="text" class="search-input" placeholder="搜索资源..." id="searchInput" oninput="handleSearch(this.value)">
        <div class="search-results" id="searchResults"></div>
      </div>
    </div>
  </header>

  <% if (it.hero) { %>
  <section class="hero">
    <div class="hero-bg" style="background-image: url('<%= it.hero.cover || '' %>')"></div>
    <div class="hero-content">
      <h1 class="hero-title"><%= it.hero.name %></h1>
      <p class="hero-desc"><%= it.hero.description || '暂无简介' %></p>
      <a href="<%= it.hero.link %>" class="hero-btn" target="_blank" rel="nofollow">获取资源</a>
    </div>
  </section>
  <% } %>

  <section class="category-section">
    <h2 class="section-title">分类导航</h2>
    <div class="category-buttons">
      <a href="category/mobile-games.html" class="category-btn">
        <span class="category-icon">📱</span>
        <span class="category-name">手机游戏</span>
      </a>
      <a href="category/pc-games.html" class="category-btn">
        <span class="category-icon">💻</span>
        <span class="category-name">电脑游戏</span>
      </a>
      <a href="category/ps4-games.html" class="category-btn">
        <span class="category-icon">🎮</span>
        <span class="category-name">PS4游戏</span>
      </a>
      <a href="category/switch-games.html" class="category-btn">
        <span class="category-icon">🕹️</span>
        <span class="category-name">SWITCH游戏</span>
      </a>
      <a href="category/short-drama.html" class="category-btn">
        <span class="category-icon">📺</span>
        <span class="category-name">短剧资源</span>
      </a>
    </div>
  </section>

  <main class="category-section">
    <h2 class="section-title">最新资源</h2>
    <div class="resource-grid" id="resourceGrid">
      <% it.latest.forEach(function(item, index) { %>
      <article class="resource-card" itemscope itemtype="https://schema.org/SoftwareApplication">
        <div class="card-cover" onclick="openModal(<%= index %>)">
          <% if (item.cover) { %>
          <img src="<%= item.cover %>" alt="<%= item.name %>封面" itemprop="image">
          <% } else { %>
          <span class="card-icon"><%= item.icon %></span>
          <% } %>
        </div>
        <div class="card-body">
          <h3 class="card-title" itemprop="name"><%= item.name %></h3>
          <div class="card-meta">
            <span class="card-tag" itemprop="applicationCategory"><%= item.categoryName %></span>
            <% if (item.size) { %><span itemprop="fileSize"><%= item.size %></span><% } %>
            <% if (item.version) { %><span itemprop="softwareVersion"><%= item.version %></span><% } %>
          </div>
          <!-- SEO: 详情直接显示，爬虫可抓取 -->
          <div class="card-detail" itemprop="description">
            <p><%= item.description || '暂无简介' %></p>
          </div>
          <!-- 隐藏的链接信息供爬虫抓取 -->
          <div style="display:none;">
            <a href="<%= item.link %>" itemprop="downloadUrl" rel="nofollow">下载链接</a>
            <% if (item.updateTime) { %>
            <time itemprop="dateModified" datetime="<%= item.updateTime %>"><%= item.updateTime %></time>
            <% } %>
          </div>
        </div>
      </article>
      <% }); %>
    </div>
  </main>

  <!-- Modal -->
  <div class="modal-overlay" id="modalOverlay" onclick="closeModalOnOverlay(event)">
    <div class="modal">
      <button class="modal-close" onclick="closeModal()">×</button>
      <div class="modal-cover" id="modalCover"></div>
      <div class="modal-body">
        <h2 class="modal-title" id="modalTitle"></h2>
        <div class="modal-info" id="modalInfo"></div>
        <p class="modal-desc" id="modalDesc"></p>
        <div id="modalLink"></div>
      </div>
    </div>
  </div>

  <footer class="footer">
    <p>© 2024 资源站 - 仅供学习交流使用</p>
  </footer>

  <!-- Fuse.js from CDN -->
  <script type="module">
    import Fuse from 'https://cdn.jsdelivr.net/npm/fuse.js@6.6.2/dist/fuse.esm.min.js';
    window.Fuse = Fuse;
  </script>
  <script src="js/search.js"></script>

  <script>
    const resources = <%= JSON.stringify(it.latest) %>;
  </script>
</body>
</html>